# Copy this file to .env and fill in your values.

# Home Assistant URL (e.g. http://homeassistant.local:8123 or http://192.168.x.x:8123)
HA_URL=http://homeassistant.local:8123

# Long-lived access token from HA → Profile → Security → Long-Lived Access Tokens
HA_TOKEN=

# Optional: override where the backend looks for config files (rooms.json etc.)
# Defaults to ./config relative to the repo root.
# CONFIG_DIR=/absolute/path/to/config

# Optional: override backend port in dev mode (default 5050)
# PORT=5050
